# Google Gemini API key (get free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_api_key_here

# GitHub token (optional, increases rate limit from 60 to 5000 req/hr)
# Get from https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=

# Target GitHub repo
GITHUB_REPO=facebook/react

# Number of issues to fetch
MAX_ISSUES=200

# Extraction batch size
EXTRACTION_BATCH_SIZE=5
